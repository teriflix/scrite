# Example configuration for Scrite packaging.
# Copy this to packaging/packaging.config.local and fill in your values.
# DO NOT commit packaging.config.local to version control!

# ============================================================================
# macOS Signing & Notarization
# ============================================================================
# MACOS_SIGNING_IDENTITY — Your "Developer ID Application" identity
# Example: "Developer ID Application: VCreate Logic (ABC123XYZ)"
# Run 'security find-identity -v -p codesigning' to list your identities.
export MACOS_SIGNING_IDENTITY=""

# APPLE_TEAM_ID — Your Apple Developer Team ID (for notarization)
export APPLE_TEAM_ID=""

# APPLE_ID_USER — Your Apple ID email
export APPLE_ID_USER=""

# APPLE_NOTARIZE_PASSWORD — App-specific password from https://appleid.apple.com
# Create an app-specific password under Security; do NOT use your regular Apple ID password.
export APPLE_NOTARIZE_PASSWORD=""

# ============================================================================
# Windows Signing
# ============================================================================
# CODESIGN_TOOL — Path to code signing tool executable
# Example: "C:\\Program Files (x86)\\CodeSignTool\\CodeSignTool.exe"
#          or "signtool.exe" if in PATH
export CODESIGN_TOOL=""

# WIN_CERT_SUBJECT — Certificate CN (Common Name) for code signing
# This should match the certificate CN from your code signing certificate.
export WIN_CERT_SUBJECT=""

# Windows dependencies (set these if not in standard locations)
export SCRITE_OPENSSL_LIBS=""      # Root of OpenSSL 1.1 x64 DLLs
export SCRITE_CRASHPAD_ROOT=""     # Root of Crashpad SDK

# ============================================================================
# Common
# ============================================================================
# SIGN_PACKAGES — Set to 1 to enable signing (macOS & Windows)
export SIGN_PACKAGES=0

# QT_BIN_DIR — Path to Qt bin directory
# Example: "$HOME/Qt/6.8.0/macos/bin"
#          or "$HOME/Qt/6.8.0/gcc_64/bin" on Linux
#          or "C:\\Qt\\6.8.0\\msvc2022_64\\bin" on Windows
# If not set, the scripts will search PATH.
export QT_BIN_DIR=""

# BUILD_DIR — CMake build directory (relative to project root)
export BUILD_DIR="build"

# ============================================================================
# Linux-specific
# ============================================================================
# LINUXDEPLOY_PATH — Path to linuxdeploy executable (auto-detected from PATH if not set)
# Download: https://github.com/linuxdeploy/linuxdeploy/releases
# Example: "$HOME/deploy-tools/linuxdeploy-x86_64.AppImage"
export LINUXDEPLOY_PATH=""

# LINUXDEPLOY_QT_PLUGIN_PATH — Path to linuxdeploy-plugin-qt executable
# Download: https://github.com/linuxdeploy/linuxdeploy-plugin-qt/releases
# Example: "$HOME/deploy-tools/linuxdeploy-plugin-qt-x86_64.AppImage"
export LINUXDEPLOY_QT_PLUGIN_PATH=""

# APPIMAGETOOL_PATH — Path to appimagetool executable (only needed with --use-appimagetool)
# Download: https://github.com/AppImage/AppImageKit/releases
export APPIMAGETOOL_PATH=""

# APPIMAGE_RUNTIME_PATH — Path to a cached AppImage type-2 runtime binary.
# If not set, the runtime is cached next to the linuxdeploy executable.
# Downloaded automatically on first use from:
#   https://github.com/AppImage/type2-runtime/releases/download/continuous/runtime-x86_64
export APPIMAGE_RUNTIME_PATH=""
